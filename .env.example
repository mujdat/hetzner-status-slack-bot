# Required: Slack incoming webhook URL
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# Language for Hetzner status page: "en" or "de" (default: "en")
HETZNER_STATUS_LANG=en

# Poll interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# Path to persist state between restarts (default: ./state.json, Docker uses /data/state.json)
STATE_FILE_PATH=./state.json
